# Rename/copy to tailscale_secrets.yml in this folder (gitignored): variables merge for group `gcp_lab`
# automatically on every playbook run — no `-e @...` needed.
#
# Tailscale keys: https://login.tailscale.com/admin/settings/keys

tailscale_auth_key: tskey-auth-REPLACE_ME________

# Uncomment if ACLs assign nodes by tag.
# tailscale_advertise_tags: "tag:gcp-lab"

# Optional nicer MagicDNS hostname.
# tailscale_hostname: "gcp-lab-vm"

# tailscale_accept_routes: false
# tailscale_enable_ssh_server: true

# Exit node defaults to apple-tv in roles/tailscale/defaults/main.yml. Override or disable:
# tailscale_exit_node: ""
# tailscale_exit_node_allow_lan_access: false
