# Repo-wide noise
.DS_Store

# Terraform (often run under infra/). Avoid committing state from a stray `terraform`
# invocation at repo root.
*.tfstate
*.tfstate.*
.terraform/

# Ansible / Python venv inside config/
config/**/.venv/
config/**/__pycache__/
config/**/*.retry

# Ansible optional Tailscale auth (copy from tailscale_secrets.yml.example in same folder)
config/inventory/group_vars/gcp_lab/tailscale_secrets.yml
# Legacy filename (prefer inventory/group_vars path so vars merge automatically)
config/secrets.tailscale.yml
