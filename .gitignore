# Repo-wide noise
.DS_Store

# Local pipeline secrets
pipelines/.env
pipelines/.venv/
pipelines/logs/
pipelines/**/__pycache__/

# Terraform (often run under infra/). Avoid committing state from a stray `terraform`
# invocation at repo root.
*.tfstate
*.tfstate.*
.terraform/

# Ansible / Python venv inside config/
config/**/.venv/
config/**/__pycache__/
config/**/*.retry
