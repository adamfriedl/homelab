# Copy to terraform.tfvars in this directory (infra/), or use TF_VAR_* in CI.
# Use the project *ID* (below), not only the Console display name "gcp-lab".

project_id = "YOUR_PROJECT_ID"
region     = "us-central1"
zone       = "us-central1-c"

# Grant yourself IAP tunnel privilege (GCP login principal). Omit list [] to skip Terraform IAM bindings.
iap_ssh_tunnel_members = [
  "user:YOU@example.com",
]

# OS Login: SSH + sudo via IAM (recommended). Grant the same principals that need Ansible/gcloud SSH.
# After apply, add your SSH key to your OS Login profile (Gmail usernames are auto-generated, e.g. you_gmail_com):
#   gcloud compute os-login ssh-keys add --key-file=~/.ssh/google_compute_engine.pub
#   gcloud compute os-login describe-profile --format='value(posixAccounts[0].username)'
os_login_admin_members = [
  "user:YOU@example.com",
  # "serviceAccount:terraform-ci@YOUR_PROJECT_ID.iam.gserviceaccount.com",
]

# Typical IAP-only stance: disable public IPs and tighten direct-Internet SSH.
enable_external_public_ip = false

# Steady state: false (no NAT charge). Set true temporarily to bootstrap apt/Tailscale on a new VM.
enable_cloud_nat = false

# SSH from arbitrary Internet IPs (narrow CIDR(s)). Leave [] to omit this rule entirely.
ssh_source_ranges = []

# Already covered by GCP when using gcloud/application-default OAuth for your login.
#
# SSH still additionally needs authorization to administer the instance (commonly
# roles/compute.osLogin on the project, or OS Login disabled with metadata SSH keys + instance admin).
# See: https://cloud.google.com/iap/docs/using-tcp-forwarding

# Optional tweaks:
# network_name              = "gcp-lab-network"
# firewall_name             = "gcp-lab-allow-ssh-ingress"
# iap_ssh_firewall_name     = "gcp-lab-allow-ssh-iap"
# enable_iap_ssh            = true
# machine_type              = "e2-micro"
# boot_disk_image           = "ubuntu-os-cloud/ubuntu-2404-lts"
#
# Multiple VMs — map key is the GCP instance name; {} inherits defaults above.
# instances = {
#   "gcp-lab-instance" = {}
#   "gcp-lab-worker"   = { machine_type = "e2-small" }
#   "gcp-lab-other"    = { zone = "us-central1-b" }
# }
